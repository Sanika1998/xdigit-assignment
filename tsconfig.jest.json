{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "types": ["jest", "@testing-library/jest-dom", "react", "react-dom", "vite/client"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "src/vite-env.d.ts",
    "jest.setup.ts"
  ],
  "exclude": []
}
